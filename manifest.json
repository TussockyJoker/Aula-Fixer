{
  "manifest_version": 3,
  "name": "Aula Ad Filter",
  "version": "1.1",
  "description": "Removes all the notifications about rooms for rent on Aula",

  "content_scripts": [
    {
      "matches": ["https://coventry.aula.education/*"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["keywords.txt"],
      "matches": ["https://coventry.aula.education/*"]
    }
  ]
}